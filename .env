# JetRoutes Environment Variables - Local Development
# DO NOT COMMIT THIS FILE TO VERSION CONTROL

# API Configuration
VITE_API_BASE_URL=http://localhost:3000
VITE_API_TIMEOUT=30000

# Email Service Configuration
VITE_EMAIL_SERVICE_URL=http://localhost:3000/email
VITE_SUPPORT_EMAIL=support@jetroutes.com

# Payment Service Configuration
VITE_PAYMENT_API_URL=http://localhost:3000/payment
VITE_STRIPE_PUBLIC_KEY=pk_test_your_test_key_here
VITE_PAYPAL_CLIENT_ID=your_sandbox_client_id_here

# Crypto Payment Configuration
VITE_CRYPTO_WALLET_ADDRESS=THQ8FBWSeRqWi9rSqkMa5xTuTL8pTbMTz7
VITE_CRYPTO_NETWORK=tron

# Application Configuration
VITE_APP_NAME=JetRoutes
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:8080
VITE_APP_ENVIRONMENT=development

# Feature Flags
VITE_ENABLE_CRYPTO_PAYMENT=true
VITE_ENABLE_BANK_TRANSFER=true
VITE_ENABLE_DIGITAL_WALLET=true

# Analytics (Optional)
VITE_GOOGLE_ANALYTICS_ID=
VITE_SENTRY_DSN=

# Development/Debug
VITE_DEBUG_MODE=true
